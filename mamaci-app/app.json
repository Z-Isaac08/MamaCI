{
  "expo": {
    "name": "MamaCi",
    "slug": "mamaci-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0F766E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ci.mamaci.app"
    },
    "android": {
      "package": "ci.mamaci.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F766E"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0F766E"
        }
      ]
    ]
  }
}
